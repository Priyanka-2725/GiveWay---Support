generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  ngo_admin
  admin
  superadmin
}

enum NgoMembershipRole {
  owner
  manager
}

enum VolunteerStatus {
  pending
  accepted
  rejected
}

enum FeedItemType {
  donation
  volunteer
  ngo_update
  recommendation
  milestone
}

model User {
  id                    String               @id @default(uuid())
  name                  String?
  email                 String               @unique
  passwordHash          String
  role                  UserRole             @default(user)
  emailVerified         Boolean              @default(false)
  followingNgoIds       String[]             @default([])
  recentSearchTerms     String[]             @default([])
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ngoMemberships        NgoMember[]
  donations             Donation[]
  volunteerRequests     VolunteerRequest[]
  notifications         Notification[]
  feedItems             FeedItem[]
  verificationTokens    VerificationToken[]
  passwordResetTokens   PasswordResetToken[]

  @@map("users")
}

model Ngo {
  id                  String             @id @default(uuid())
  name                String
  shortDescription    String?
  description         String
  cause               String
  city                String?
  state               String
  goalAmount          Decimal            @default(0) @db.Decimal(12, 2)
  raisedAmount        Decimal            @default(0) @db.Decimal(12, 2)
  verified            Boolean            @default(false)
  image               String?
  icon                String?
  contactEmail        String?
  impactScore         Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  members             NgoMember[]
  donations           Donation[]
  volunteerRequests   VolunteerRequest[]

  @@map("ngos")
}

model NgoMember {
  id              String            @id @default(uuid())
  userId          String
  ngoId           String
  membershipRole  NgoMembershipRole
  createdAt       DateTime          @default(now())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ngo             Ngo               @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@unique([userId, ngoId])
  @@map("ngo_members")
}

model Donation {
  id          String    @id @default(uuid())
  userId      String
  ngoId       String
  amount      Decimal   @db.Decimal(12, 2)
  message     String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ngo         Ngo       @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@map("donations")
}

model VolunteerRequest {
  id           String           @id @default(uuid())
  userId       String
  ngoId        String
  skills       String?
  availability String?
  message      String?
  status       VolunteerStatus  @default(pending)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ngo          Ngo              @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@map("volunteer_requests")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  title       String
  message     String
  read        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model FeedItem {
  id          String        @id @default(uuid())
  userId      String
  type        FeedItemType
  title       String
  message     String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feed_items")
}

model VerificationToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
